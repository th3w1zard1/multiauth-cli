{
  "name": "multiauth-cli",
  "version": "0.1.0",
  "description": "Pluggable multiauth layer for any CLI: round-robin, failover, optional accounts file + helper",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./wrapper/run": "./dist/wrapper/run.js",
    "./wrapper/types": "./dist/wrapper/types.js"
  },
  "bin": {
    "multiauth": "./dist/main.js",
    "multiauth-accounts": "./dist/accounts-cli.js",
    "multiauth-run": "./dist/run-config-cli.js",
    "multiauth-firecrawl": "./dist/firecrawl-main.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "docs",
    "examples",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "verify:shim": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/verify-shim.ps1",
    "prepublishOnly": "npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "multiauth",
    "api-key",
    "key-rotation",
    "load-balance",
    "wrapper",
    "pluggable-adapter"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.7.0"
  },
  "optionalDependencies": {
    "firecrawl-cli": "^1.15.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
